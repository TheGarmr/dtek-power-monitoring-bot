{
  "name": "power-monitoring-bot",
  "version": "0.0.1",
  "description": "DTEK power outages monitor",
  "type": "module",
  "main": "src/monitor.js",
  "scripts": {
    "start": "node --env-file=.env ./src/monitor.js",
    "start:service": "node --env-file=.env ./src/server.js",
    "watch": "node --env-file=.env --watch ./src/monitor.js",
    "watch:service": "node --env-file=.env --watch ./src/server.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.55.0"
  },
  "engines": {
    "node": ">=22.15.1"
  },
  "keywords": [
    "monitor",
    "power",
    "outages",
    "bot",
    "telegram",
    "dtek",
    "ntfy"
  ],
  "author": "TheGarmr",
  "license": "MIT"
}
